# Copy this file to .env and fill in your keys
# LLM: optional — OpenAI 우선, 없으면 Anthropic, 둘 다 없으면 mock LLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# DART OpenAPI key (required for live DART fetch; sample data works without it)
# Get one at https://opendart.fss.or.kr/
DART_API_KEY=

# Azure AI Document Intelligence — 정형 증빙 OCR (전기요금·가스·폐기물 대장)
# Azure 포털 > Document Intelligence 리소스 > "키 및 엔드포인트"에서 복사
# 없으면 pymupdf+정규식(디지털 PDF) → mock 으로 폴백
AZURE_DOC_INTEL_ENDPOINT=
AZURE_DOC_INTEL_KEY=
# Azure OpenAI(Foundry) 엔드포인트 — gpt-4.1-mini 판정/생성/OCR 후처리
AZURE_OPENAI_ENDPOINT=

# Model selection
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # LLM 2차 판정용 (저비용 기본값)
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# 하이브리드 검출 (룰 1차 + LLM 2차 판정)
# JUDGE_TRIGGER=0.25       # 룰 점수가 이 값 이상인 축만 LLM 판정 (비용 제어)
# JUDGE_RULE_WEIGHT=0.4    # 최종 = 0.4*룰 + 0.6*LLM
# ESGENIE_FORCE_MOCK=1     # 키가 있어도 mock 강제 (테스트/오프라인 데모)
