# Copy this file to .env and fill in your keys
# OpenAI: optional — ESGenie falls back to a template-based mock LLM if absent
OPENAI_API_KEY=

# DART OpenAPI key (required for live DART fetch; sample data works without it)
# Get one at https://opendart.fss.or.kr/
DART_API_KEY=

# Model selection
OPENAI_MODEL=gpt-4o-mini
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
